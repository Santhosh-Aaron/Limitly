# ─── Limitly Backend — Render Environment Variables ──────────────────────────
# Set these in: Render Dashboard → Your Web Service → Environment

# ── Database (your production PostgreSQL) ──
DB_URL=jdbc:postgresql://your-host:5432/your-db-name
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# ── JWT ──
# Generate a strong 256-bit hex key for production:
#   openssl rand -hex 32
JWT_SECRET=your-production-jwt-secret-256-bit-hex
JWT_EXPIRATION_MS=86400000

# ── Google OAuth ──
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── CORS ──
# Your Vercel frontend URL (no trailing slash)
CORS_ALLOWED_ORIGINS=https://your-limitly-frontend.vercel.app

# ── Email (SMTP) ──
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# ── App Mode ──
APP_DEV_MODE=false
